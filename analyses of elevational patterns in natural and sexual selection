### test if we need to account for higher-level phylogenetic relatedness in informal analysis
inf01a <- lmer(linear.coefs ~ elevation + abs.Lat + (1|StudyID) + (1|Species), data = ssd)
inf01b <- lmer(linear.coefs ~ elevation + abs.Lat + (1|StudyID) + (1|Species) + (1|Order) + (1|Class), data = ssd)
AICc(inf01a, inf01b)


