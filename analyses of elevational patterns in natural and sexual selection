############## Does the strength of natural selection for larger bodies INCREASE at higher elevations?
surv <- read.csv('surv.elev.csv')
surv <- subset(surv, linear.coefs <3) # one massive outlier (B=3.80). remove it

s.mod01 <- lmer(linear.coefs ~ elevation + abs.Lat + (1|StudyID) + (1|Species), data = surv)
summary(s.mod01)
# Linear mixed model fit by REML. t-tests use Satterthwaite's method ['lmerModLmerTest']
# Formula: linear.coefs ~ elevation + abs.Lat + (1 | StudyID) + (1 | Species)
   # Data: surv

# REML criterion at convergence: -496.7

# Scaled residuals: 
    # Min      1Q  Median      3Q     Max 
# -8.5466 -0.3564 -0.0879  0.2686  8.8521 

# Random effects:
 # Groups   Name        Variance Std.Dev.
 # StudyID  (Intercept) 0.003261 0.05711 
 # Species  (Intercept) 0.004321 0.06573 
 # Residual             0.034184 0.18489 
# Number of obs: 1085, groups:  StudyID, 35; Species, 23

# Fixed effects:
              # Estimate Std. Error         df t value Pr(>|t|)  
# (Intercept) -8.183e-02  6.717e-02  3.081e+01  -1.218   0.2324  
# elevation    3.368e-06  3.722e-05  1.447e+02   0.090   0.9280  
# abs.Lat      2.694e-03  1.417e-03  2.678e+01   1.901   0.0681 .
# ---
# Signif. codes:  0 ‘***’ 0.001 ‘**’ 0.01 ‘*’ 0.05 ‘.’ 0.1 ‘ ’ 1

# Correlation of Fixed Effects:
          # (Intr) elevtn
# elevation  0.035       
# abs.Lat   -0.951 -0.150

confint(s.mod01, parm = 'elevation')
                  # 2.5 %       97.5 %
# elevation -6.906787e-05 7.574371e-05

#### do we need to account for any higher-level phylogenetic relatedness?
s.mod01a <- lmer(linear.coefs ~ elevation + abs.Lat + (1|StudyID) + (1|Species) + (1|order) + (1|class), data = surv)
AICc(s.mod01a,s.mod01)
         # df      AICc
# s.mod01a  8 -481.0529
# s.mod01   6 -484.5820

## nope




###### formal meta-analysis
proper.se <- proper[which(!is.na(proper$linear.coefs.se)),]
dim(proper.se)


meta01 <- rma.mv(linear.coefs ~ elevation + abs.Lat, random = list(~1|StudyID, ~1|Species),  V = (surv$linear.coefs.se)^2, data = surv)
meta01$beta[2]
#-0.0001368197
meta01$se[2]
#8.03162e-05

meta01$ci.ub[2] # upper CI for elevation
# 2.059711e-05
meta01$ci.lb[2] # lower CI for elevation
# -0.0002942366
### CIs overlap 0


